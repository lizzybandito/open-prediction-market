# Backend Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=production
PORT=3000

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/predictd?schema=public"

# JWT secrets — use long, random strings (min 32 chars)
JWT_SECRET="change_me_to_a_random_string_at_least_32_chars"
JWT_REFRESH_SECRET="change_me_to_a_different_random_string_at_least_32_chars"

# Your deployed frontend URL (for CORS)
FRONTEND_URL="https://your-domain.com"

# Solana RPC URL
BLOCKCHAIN_RPC_URL="https://api.mainnet-beta.solana.com"
